# ELK Stack version
ELASTIC_VERSION=8.12.2

# Elasticsearch heap size (adjust based on available RAM)
ES_JAVA_OPTS=-Xms512m -Xmx512m

# Kibana port exposed on the host (access via http://<your-vps-ip>:5601)
KIBANA_PORT=5601

# Elasticsearch port (internal use; also exposed for direct queries)
ELASTICSEARCH_PORT=9200
